# CylinderPro environment variables.
# Copy this file to `.env` (same directory) and fill in real values.
# NEVER commit the real .env — it is git-ignored.

# Backend HTTP port
PORT=3001

# MongoDB connection string (local mongod, or MongoDB Atlas — browse either with MongoDB Compass).
MONGODB_URI=mongodb://localhost:27017/cylinder_management

# REQUIRED. Secret used to sign/verify JWTs. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# production | development. Controls log verbosity, file logging, and the JWT-secret guard.
NODE_ENV=production

# Comma-separated list of browser origins allowed by CORS (Vite's dev + preview servers by default).
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:4173

# Gmail SMTP for OTP / verification emails (Phase 19). Use a Gmail App Password
# (Google Account → Security → 2-Step Verification → App passwords), never the real password.
# Without SMTP_HOST the app falls back to logging emails on the server console (dev only).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_gmail_address@gmail.com
